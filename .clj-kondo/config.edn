;; kg_checkpoint.cljc's Datalog :where clauses use multi-segment attribute
;; keywords like :kg/claim/thread (namespace "kg", name "claim/thread") --
;; valid per the real Clojure reader (verified: (namespace :kg/claim/thread)
;; => "kg", (name :kg/claim/thread) => "claim/thread") and load-bearing,
;; matching the kotobase-kg-v1 attribute scheme. clj-kondo's own reader
;; rejects this style as "Invalid keyword", so :syntax is disabled here.
{:linters {:syntax {:level :off}}}
