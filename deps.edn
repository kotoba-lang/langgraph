{:paths ["src"]
 ;; Only dependency is langchain-clj (itself zero-dep, all .cljc) —
 ;; the same layering as upstream langchain-core / langgraph (ADR-0001).
 ;; Bumped past langchain#7/#8: parse-query's malformed-adjacent-marker
 ;; misparse fix and transact!'s swap!-retry-safety fix (the latter is
 ;; directly consequential here -- datomic-checkpointer's -put! calls
 ;; transact! for every superstep write).
 :deps {io.github.kotoba-lang/langchain
        {:git/sha "0f8a15af0fc11bd998d0720ed23f5065d3e1c736"}}
 :aliases
 {:test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; local checkout for workspace development (orgs/kotoba-lang/*)
  :dev {:override-deps {io.github.kotoba-lang/langchain
                        {:local/root "../langchain"}}}
  ;; clj-kondo as a Clojars lib (no Homebrew/system install needed).
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test"
                     "--fail-level" "error"]}}}
